<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"></head>
<body style="margin:0;padding:0;background:#0b1120;font-family:'Segoe UI',Arial,sans-serif;">
  <div style="max-width:520px;margin:40px auto;background:#111827;border:1px solid rgba(201,168,76,.2);border-radius:16px;overflow:hidden;">
    <div style="background:linear-gradient(135deg,#c9a84c,#a07830);padding:28px 32px;text-align:center;">
      <div style="font-size:22px;font-weight:800;color:#0b1120;">SwiftRoute</div>
      <div style="font-size:10px;color:rgba(11,17,32,.6);letter-spacing:.12em;text-transform:uppercase;margin-top:4px;">UK Logistics</div>
    </div>
    <div style="padding:36px 32px;text-align:center;">
      <div style="width:64px;height:64px;background:rgba(34,197,94,.1);border:2px solid rgba(34,197,94,.3);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:20px;font-size:28px;">🔒</div>
      <h2 style="font-size:20px;font-weight:800;color:#fff;margin:0 0 10px;">Password Changed</h2>
      <p style="font-size:14px;color:#9ca3af;line-height:1.7;margin:0 0 24px;">
        Hi <strong style="color:#fff;"><%= firstName %></strong>, your SwiftRoute password was successfully changed.<br>
        If you did not make this change, please contact us immediately.
      </p>
      <a href="mailto:support@swiftroute.co.uk" style="display:inline-block;background:linear-gradient(135deg,#c9a84c,#a07830);color:#0b1120;font-weight:700;font-size:13px;padding:12px 28px;border-radius:8px;text-decoration:none;">Contact Support</a>
    </div>
    <div style="padding:16px 32px;border-top:1px solid rgba(255,255,255,.06);text-align:center;">
      <p style="font-size:11px;color:#4b5563;margin:0;">© <%= new Date().getFullYear() %> Swift Route Ltd · Registered in England & Wales</p>
    </div>
  </div>
</body>
</html>
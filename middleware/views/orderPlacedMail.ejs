<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"></head>
<body style="margin:0;padding:0;background:#0b1120;font-family:'Segoe UI',Arial,sans-serif;">
  <div style="max-width:560px;margin:40px auto;background:#111827;border:1px solid rgba(201,168,76,.2);border-radius:16px;overflow:hidden;">
    <div style="background:linear-gradient(135deg,#c9a84c,#a07830);padding:28px 32px;text-align:center;">
      <div style="font-size:22px;font-weight:800;color:#0b1120;">SwiftRoute</div>
      <div style="font-size:10px;color:rgba(11,17,32,.6);letter-spacing:.12em;text-transform:uppercase;margin-top:4px;">UK Logistics</div>
    </div>
    <div style="padding:36px 32px;">
      <h2 style="font-size:20px;font-weight:800;color:#fff;margin:0 0 6px;">Order Confirmed 📦</h2>
      <p style="font-size:14px;color:#9ca3af;margin:0 0 28px;">Hi <strong style="color:#fff;"><%= firstName %></strong>, your order has been placed and is awaiting a driver.</p>
      <div style="background:#0b1120;border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:20px;margin-bottom:20px;">
        <div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.1em;margin-bottom:14px;">Order Details</div>
        <table style="width:100%;border-collapse:collapse;">
          <tr><td style="padding:6px 0;font-size:13px;color:#9ca3af;width:40%;">Order No.</td><td style="font-size:13px;font-weight:700;color:#c9a84c;"><%= orderNumber %></td></tr>
          <tr><td style="padding:6px 0;font-size:13px;color:#9ca3af;">Item</td><td style="font-size:13px;color:#fff;"><%= description %> · <%= weightKg %>kg</td></tr>
          <tr><td style="padding:6px 0;font-size:13px;color:#9ca3af;">Collection</td><td style="font-size:13px;color:#fff;"><%= pickup %></td></tr>
          <tr><td style="padding:6px 0;font-size:13px;color:#9ca3af;">Delivery</td><td style="font-size:13px;color:#fff;"><%= delivery %></td></tr>
          <tr style="border-top:1px solid rgba(255,255,255,.06);">
            <td style="padding:10px 0 4px;font-size:13px;color:#9ca3af;">Total</td>
            <td style="font-size:16px;font-weight:800;color:#c9a84c;padding-top:10px;">£<%= typeof total === 'number' ? total.toFixed(2) : total %></td>
          </tr>
        </table>
      </div>
      <p style="font-size:13px;color:#6b7280;text-align:center;">We'll email you again once a driver is assigned.</p>
    </div>
    <div style="padding:16px 32px;border-top:1px solid rgba(255,255,255,.06);text-align:center;">
      <p style="font-size:11px;color:#4b5563;margin:0;">© <%= new Date().getFullYear() %> Swift Route Ltd · Registered in England & Wales</p>
    </div>
  </div>
</body>
</html>